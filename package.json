{
  "name": "leitner",
  "version": "0.1.0",
  "description": "A small TypeScript routing library for client-side single-page applications.",
  "type": "module",
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "workspaces": [
    "examples/*"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "smoke": "node scripts/smoke.mjs",
    "prepublishOnly": "npm run build && npm test && npm run smoke"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "jsdom": "^25.0.1",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
